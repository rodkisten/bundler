{
  "name": "rod-browser-toolbox",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Root-entry browser bundle publisher that emits one IIFE global per root source file, plus ESM builds, docs, and a generated landing page.",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.5.1"
  },
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsx scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "pnpm typecheck && pnpm test && pnpm build",
    "publish:gist": "tsx scripts/publish-gist.ts",
    "bench:all": "tsx scripts/benchmarks.ts --mode=single --rounds=1",
    "bench": "tsx scripts/benchmarks.ts --mode=single --rounds=1",
    "bench:cipo": "tsx scripts/benchmarks.ts --mode=single --suite=cipo --rounds=1",
    "bench:cipo:memory": "node --expose-gc --import tsx scripts/cipo-memory-benchmark.ts",
    "build:with-bench": "pnpm build && pnpm bench:ci",
    "bench:ci": "tsx scripts/benchmarks.ts --mode=single --rounds=3",
    "bench:fabrica": "tsx scripts/benchmarks.ts --mode=single --suite=fabrica --rounds=1",
    "bench:cipo:raw": "vitest bench src/cipo/tests/cipo.bench.ts --run",
    "bench:fabrica:raw": "vitest bench src/fabrica/tests/fabrica.bench.ts --run",
    "bench:reliable": "tsx scripts/benchmarks.ts --mode=single --rounds=3",
    "bench:compare": "tsx scripts/benchmarks.ts --mode=compare --rounds=3",
    "dev:devtools": "vite --config ./src/devtools/vite.config.ts"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "esbuild": "0.28.0",
    "jsdom": "^29.1.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "@types/markdown-it": "^14.1.2",
    "vite": "8.1.2"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "lit": "^3.3.1",
    "lit-html": "^3.3.1",
    "stylis": "^4.3.6"
  }
}
