{
  "name": "private-ts-bundler-publisher",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Bundle a private TypeScript entrypoint and publish browser-ready JavaScript to GitHub Releases, Pages, and optionally a public Gist.",
  "scripts": {
    "build": "tsx scripts/build.ts",
    "publish:gist": "tsx scripts/publish-gist.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "esbuild": "^0.25.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
