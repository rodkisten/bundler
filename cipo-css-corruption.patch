diff --git a/src/cipo/tests/cipo.css-corruption-regressions.test.ts b/src/cipo/tests/cipo.css-corruption-regressions.test.ts
new file mode 100644
index 0000000..5555555
--- /dev/null
+++ b/src/cipo/tests/cipo.css-corruption-regressions.test.ts
@@ -0,0 +1,105 @@
+import { beforeEach, describe, expect, it } from 'vitest'
+import { getCssText, reset, setup, sheet } from '../src/index'
+
+describe('Cipó CSS corruption regressions', () => {
+  beforeEach(() => {
+    reset()
+    setup({
+      prefix: 'reg',
+      layers: false,
+      minify: true,
+      theme: {
+        colors: {
+          strong: '#ffffff',
+          panel: '#111111',
+          cyan: '#00ffff',
+          danger: '#ff0000',
+        },
+      },
+    })
+  })
+
+  it('preserves native CSS properties instead of destructive aliases', () => {
+    const artifact = sheet.css`
+      .native-properties {
+        font: 600 11px / 1 var(--font-ui)
+        content: ""
+        transform: translateX(-50%)
+        direction: rtl
+        grid: auto-flow / 1fr 2fr
+      }
+    `
+    const css = String(artifact)
+
+    expect(css).toContain('font:600 0.6875rem / 1 var(--font-ui)')
+    expect(css).toContain('content:""')
+    expect(css).toContain('transform:translateX(-50%)')
+    expect(css).toContain('direction:rtl')
+    expect(css).toContain('grid:auto-flow / 1fr 2fr')
+    expect(css).not.toContain('font-family:calc(')
+    expect(css).not.toContain('align-content:""')
+    expect(css).not.toContain('text-transform:translateX(')
+  })
+
+  it('keeps multiline nested selector lists intact', () => {
+    const artifact = sheet.css`
+      .details-resize {
+        &::before {
+          content: ""
+          transform: translateX(-50%)
+        }
+
+        &:hover::before,
+        &:focus-visible::before {
+          background: red
+        }
+      }
+    `
+    const css = String(artifact)
+
+    expect(css).toContain('.details-resize::before')
+    expect(css).toContain('.details-resize:hover::before,.details-resize:focus-visible::before')
+    expect(css).not.toContain('&:hover')
+    expect(css).not.toContain(';&')
+  })
+
+  it('emits token colors and resolves runtime variables in one-line blocks', () => {
+    const artifact = sheet.css`:root { $colors(strong: #fff, panel: #111, cyan: #0ff); $$strong: $colors.strong; $$detailsHeight: 280px; } .layout { grid-template-rows: minmax(0, 1fr) auto minmax(0, $$detailsHeight); }`
+    const css = String(artifact)
+
+    expect(css).toContain('--reg-colors-strong:#fff')
+    expect(css).toContain('--reg-colors-panel:#111')
+    expect(css).toContain('--reg-colors-cyan:#0ff')
+    expect(css).toContain('--reg-strong:var(--reg-colors-strong)')
+    expect(css).toContain('minmax(0, var(--reg-details-height))')
+    expect(css).not.toContain('$$')
+  })
+
+  it('hydrates theme CSS generated before document.head exists', async () => {
+    document.head?.remove()
+
+    reset()
+    setup({
+      prefix: 'early',
+      layers: false,
+      theme: { colors: { strong: '#abcdef' } },
+    })
+
+    expect(document.getElementById('cipo-runtime-style')).toBeNull()
+    expect(getCssText()).toContain('--early-colors-strong')
+
+    const head = document.createElement('head')
+    document.documentElement.insertBefore(head, document.body)
+    document.dispatchEvent(new Event('readystatechange'))
+    await Promise.resolve()
+
+    const style = document.getElementById('cipo-runtime-style')
+    expect(style?.textContent).toContain('--early-colors-strong:#abcdef')
+  })
+})
